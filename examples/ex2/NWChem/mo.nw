Title "methylamine MO Cube"

start mo 
memory 10000 mb
permanent_dir ./
scratch_dir ./scr

geometry  # optimized geometry!!
 LOAD methylamine-006.xyz
end

basis
 * library 6-31G
end

dft
 xc b3lyp
 iterations 500
 mulliken
 vectors output mo.movecs
end

task dft energy

dplot 
  LimitXYZ
  -4.0 4.0 20
  -4.0 4.0 20
  -4.0 4.0 20
 vectors mo.movecs
 gaussian 
 orbitals view; 1; 9;  
 output mo09.cube
end

